#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main() {
    char text[1000];
    printf("Введите текст: ");
    fgets(text, sizeof(text), stdin);

    int length = strlen(text);
    int start = -1; // Индекс начала текущего слова

    for (int i = 0; i <= length; i++) {
        // Если текущий символ - буква и начало слова не задано
        if (isalpha((unsigned char)text[i]) && start == -1) {
            start = i; // Запоминаем начало слова
        }
        // Если текущий символ не буква (или конец строки) и слово началось
        else if (!isalpha((unsigned char)text[i]) && start != -1) {
            int end = i - 1; // Индекс последней буквы слова

            // Меняем местами первую и последнюю букву, если в слове хотя бы 2 буквы
            if (end > start) {
                char temp = text[start];
                text[start] = text[end];
                text[end] = temp;
            }
            // Для слов из 2 букв (end == start + 1) тоже выполняется обмен
            start = -1; // Сброс для поиска следующего слова
        }
    }

    printf("Результат: %s\n", text);
    return 0;
}